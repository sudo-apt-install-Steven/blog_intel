---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TopicSidebar from "../../components/TopicSidebar.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Todas las entradas de Miraidon Blogs en español.">
  <section class="page-hero">
    <div class="container">
      <div class="section-heading">
        <span class="eyeless-label">Archivo editorial</span>
        <h1>Blog</h1>
        <p>
          Entradas organizadas por tema, con imágenes, videos, comentarios locales y enlaces a fuentes oficiales cuando aparecen datos técnicos.
        </p>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container editorial-note">
      <span class="eyeless-label">Cómo leerlo</span>
      <div>
        <h2>Un archivo vivo, no una lista de tarjetas.</h2>
        <p>
          El blog está organizado como una revista técnica breve: las entradas sobre procesadores explican el camino desde el silicio hasta la experiencia del usuario; las de Intel Arc observan la GPU como pieza de juego, creación y multimedia; las guías ayudan a traducir especificaciones en decisiones reales de compra, estudio o montaje.
        </p>
        <p>
          Para leerlo con calma, empieza por la portada animada, sigue con los artículos destacados y usa la barra lateral para saltar entre temas. Cada entrada tiene fecha, categoría, etiquetas, índice interno cuando conviene, una caja de comentarios local y una nota de fuentes cuando se mencionan datos verificables.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container layout-with-sidebar">
      <div class="grid-3">
        {posts.map((post) => <ArticleCard post={post} headingLevel="h2" />)}
      </div>
      <TopicSidebar />
    </div>
  </section>
</BaseLayout>
