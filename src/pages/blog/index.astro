---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TopicSidebar from "../../components/TopicSidebar.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="Todas las entradas de Miraidon Blogs en español.">
  <section class="page-hero">
    <div class="container">
      <div class="section-heading">
        <span class="eyeless-label">Archivo editorial</span>
        <h1>Blog</h1>
        <p>
          Entradas organizadas por tema, con imágenes, videos, comentarios locales y enlaces a fuentes oficiales cuando aparecen datos técnicos.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container layout-with-sidebar">
      <div class="grid-3">
        {posts.map((post) => <ArticleCard post={post} headingLevel="h2" />)}
      </div>
      <TopicSidebar />
    </div>
  </section>
</BaseLayout>
