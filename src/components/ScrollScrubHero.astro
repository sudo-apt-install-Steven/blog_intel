---
---

<section class="scrub-shell" data-scrub-hero aria-label="Vista expandida de un procesador Intel">
  <div class="scrub-sticky">
    <video
      class="scrub-video-glow"
      data-scrub-glow
      poster="/media/posters/cpu-xeon-closed.jpg"
      preload="auto"
      muted
      playsinline
      aria-hidden="true"
    >
      <source src="/media/video/cpu-intel-xeon-exploded-scroll.mp4?v=keyframe-scrub" type="video/mp4" />
    </video>
    <video
      class="scrub-video"
      data-scrub-video
      poster="/media/posters/cpu-xeon-closed.jpg"
      preload="auto"
      muted
      playsinline
      aria-label="Video de un procesador Intel pasando de vista completa a vista expandida"
    >
      <source src="/media/video/cpu-intel-xeon-exploded-scroll.mp4?v=keyframe-scrub" type="video/mp4" />
    </video>
    <div class="scrub-vector-field" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="scrub-frame-readout" aria-hidden="true">FRAME <span data-scrub-frame>001</span> / 192</div>
    <div class="scrub-panel">
      <h1 aria-label="El chip, capa por capa.">El chip,<br />capa por capa.</h1>
      <p>
        Un blog en español para mirar la tecnología Intel con calma: procesadores, gráficos Arc, IA,
        ecosistema PC y las decisiones que conectan silicio con experiencia real.
      </p>
      <div class="button-row">
        <a class="button" href="/blog/">Explorar el blog</a>
        <a class="button secondary" href="/trabajo-escolar/">Ver trabajo escolar</a>
      </div>
      <div class="scrub-meter" aria-hidden="true">
        <span>Desplaza para abrir el procesador</span>
        <span></span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const shell = document.querySelector("[data-scrub-hero]");
    const video = document.querySelector("[data-scrub-video]");
    const glow = document.querySelector("[data-scrub-glow]");
    if (!shell || !video) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      shell.classList.add("is-static");
      video.pause();
      glow?.pause();
      return;
    }

    const frameReadout = document.querySelector("[data-scrub-frame]");
    let duration = 8;
    let targetTime = 0;
    let renderedTime = 0;
    let rafId = 0;
    video.pause();
    glow?.pause();

    const clamp = (value) => Math.min(1, Math.max(0, value));
    const updateTarget = () => {
      const rect = shell.getBoundingClientRect();
      const scrollDistance = Math.max(1, shell.offsetHeight - window.innerHeight);
      const progress = clamp((0 - rect.top) / scrollDistance);
      const shift = progress * 34;
      shell.style.setProperty("--scrub-progress", progress.toFixed(4));
      shell.style.setProperty("--scrub-progress-percent", `${(progress * 100).toFixed(2)}%`);
      shell.style.setProperty("--scrub-overlay-opacity", (0.42 + progress * 0.22).toFixed(3));
      shell.style.setProperty("--scrub-vector-opacity", (0.18 + progress * 0.48).toFixed(3));
      shell.style.setProperty("--scrub-shift", `${shift.toFixed(2)}px`);
      shell.style.setProperty("--scrub-shift-y", `${(-shift * 0.38).toFixed(2)}px`);
      shell.style.setProperty("--scrub-shift-half", `${(shift * 0.5).toFixed(2)}px`);
      shell.style.setProperty("--scrub-shift-half-neg", `${(-shift * 0.6).toFixed(2)}px`);
      shell.style.setProperty("--scrub-shift-small-neg", `${(-shift * 0.3).toFixed(2)}px`);
      shell.style.setProperty("--scrub-shift-subtle-neg", `${(-shift * 0.2).toFixed(2)}px`);
      shell.style.setProperty("--scrub-shift-wide", `${(shift * 0.7).toFixed(2)}px`);
      if (frameReadout) frameReadout.textContent = String(Math.round(progress * 191) + 1).padStart(3, "0");
      targetTime = progress * duration;
    };

    const tick = () => {
      const delta = targetTime - renderedTime;
      renderedTime += delta * 0.16;

      if (Math.abs(delta) < 0.002) {
        renderedTime = targetTime;
      }

      if (Number.isFinite(renderedTime) && Math.abs(video.currentTime - renderedTime) > 0.004) {
        const nextTime = Math.min(duration, Math.max(0, renderedTime));
        video.currentTime = nextTime;
        if (glow) glow.currentTime = nextTime;
      }

      rafId = window.requestAnimationFrame(tick);
    };

    video.addEventListener("loadedmetadata", () => {
      duration = video.duration || 8;
      updateTarget();
      if (!rafId) tick();
    });

    window.addEventListener("scroll", updateTarget, { passive: true });
    window.addEventListener("resize", updateTarget);
    updateTarget();
    tick();
  })();
</script>
