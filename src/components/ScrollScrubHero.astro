---
---

<section class="scrub-shell" data-scrub-hero aria-label="Vista expandida de un procesador Intel Core">
  <div class="scrub-sticky">
    <video
      class="scrub-video"
      data-scrub-video
      poster="/media/posters/cpu-clean-transparent.png"
      preload="auto"
      muted
      playsinline
      aria-label="Video de un procesador Intel Core pasando de vista completa a vista expandida"
    >
      <source src="/media/video/cpu-intel-core-exploded-clean.webm" type="video/webm" />
      <source src="/media/video/cpu-intel-core-exploded-smooth.mp4" type="video/mp4" />
    </video>
    <div class="scrub-panel">
      <h1>El chip,<br />capa por capa.</h1>
      <p>
        Un blog en español para mirar la tecnología Intel con calma: procesadores, gráficos Arc, IA,
        ecosistema PC y las decisiones que conectan silicio con experiencia real.
      </p>
      <div class="button-row">
        <a class="button" href="/blog/">Explorar el blog</a>
        <a class="button secondary" href="/trabajo-escolar/">Ver trabajo escolar</a>
      </div>
      <div class="scrub-meter" aria-hidden="true">
        <span>Desplaza para abrir el procesador</span>
        <span></span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const shell = document.querySelector("[data-scrub-hero]");
    const video = document.querySelector("[data-scrub-video]");
    if (!shell || !video) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      shell.classList.add("is-static");
      video.pause();
      return;
    }

    let duration = 7.4;
    let targetTime = 0;
    let renderedTime = 0;
    let rafId = 0;
    video.pause();

    const clamp = (value) => Math.min(1, Math.max(0, value));
    const updateTarget = () => {
      const rect = shell.getBoundingClientRect();
      const scrollDistance = Math.max(1, shell.offsetHeight - window.innerHeight);
      const progress = clamp((0 - rect.top) / scrollDistance);
      shell.style.setProperty("--scrub-progress", progress.toFixed(4));
      targetTime = progress * duration;
    };

    const tick = () => {
      const delta = targetTime - renderedTime;
      renderedTime += delta * 0.22;

      if (Math.abs(delta) < 0.006) {
        renderedTime = targetTime;
      }

      if (Number.isFinite(renderedTime) && Math.abs(video.currentTime - renderedTime) > 0.012) {
        video.currentTime = renderedTime;
      }

      rafId = window.requestAnimationFrame(tick);
    };

    video.addEventListener("loadedmetadata", () => {
      duration = Math.min(video.duration || 7.4, 7.4);
      updateTarget();
      if (!rafId) tick();
    });

    window.addEventListener("scroll", updateTarget, { passive: true });
    window.addEventListener("resize", updateTarget);
    updateTarget();
    tick();
  })();
</script>
