---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/blog/", label: "Blog" },
  { href: "/categorias/procesadores/", label: "Procesadores" },
  { href: "/categorias/graficos-intel-arc/", label: "Intel Arc" },
  { href: "/trabajo-escolar/", label: "Tarea" }
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Ir al inicio">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-copy">
        <span>Bitácora Intel</span>
        <small>Blog educativo</small>
      </span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      {links.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>

    <div class="header-tools">
      <button class="theme-toggle" type="button" aria-label="Cambiar tema" data-theme-toggle>
        <svg class="moon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 14.4A8.2 8.2 0 0 1 9.6 3a8.8 8.8 0 1 0 11.4 11.4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        </svg>
        <svg class="sun" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 5V2m0 20v-3m7-7h3M2 12h3m12.95-4.95 2.12-2.12M3.93 20.07l2.12-2.12m0-11.9L3.93 3.93m16.14 16.14-2.12-2.12M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <a class="header-action" href="/blog/">Leer artículos</a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const button = document.querySelector("[data-theme-toggle]");
    if (!button) return;
    button.addEventListener("click", () => {
      const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
    });
  })();
</script>
