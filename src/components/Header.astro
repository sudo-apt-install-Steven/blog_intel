---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/blog/", label: "Blog" },
  { href: "/categorias/procesadores/", label: "Procesadores" },
  { href: "/categorias/graficos-intel-arc/", label: "Intel Arc" },
  { href: "/trabajo-escolar/", label: "Tarea" }
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Ir al inicio">
      <img class="brand-mark" src="/media/brand/miraidon-logo.webp" alt="" width="40" height="40" />
      <span class="brand-copy">
        <span>Miraidon Blogs</span>
        <small>Blog educativo</small>
      </span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      {links.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>

    <div class="header-tools">
      <a class="header-action" href="/blog/">Leer artículos</a>
    </div>
  </div>
</header>
